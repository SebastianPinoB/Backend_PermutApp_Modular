SUPABASE_DB_URL=jdbc:postgresql://<mensajeria-supabase-host>:5432/postgres?sslmode=require
SUPABASE_DB_USER=<mensajeria-db-user>
SUPABASE_DB_PASSWORD=<mensajeria-db-password>
DB_MAX_POOL_SIZE=2
SERVICIO_USUARIOS_BASE_URL=http://127.0.0.1:5001
SERVICIO_PUBLICACIONES_BASE_URL=http://127.0.0.1:6000
JWT_SECRET=<same-jwt-secret-used-by-auth-service>
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006,http://192.168.1.105:8081,http://192.168.1.105:19006
